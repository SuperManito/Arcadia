{
  "name": "arcadia",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start --no-minify",
    "build": "docusaurus build --no-minify",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "lint": "eslint ./src --ext .ts,tsx,js,jsx,mjs,mdx",
    "lint:fix": "eslint --fix ./src --ext .ts,tsx,js,jsx,mjs,mdx",
    "prepare": "husky install",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@algolia/client-search": "^4.17.0",
    "@docusaurus/core": "^2.4.3",
    "@docusaurus/preset-classic": "2.4.3",
    "@docusaurus/remark-plugin-npm2yarn": "^2.4.3",
    "@docusaurus/theme-classic": "^2.4.3",
    "@docusaurus/theme-common": "^2.4.3",
    "@iconify/react": "^4.1.0",
    "@mdx-js/react": "^1.6.22",
    "antd": "^5.9.2",
    "clsx": "^1.2.1",
    "docusaurus-plugin-image-zoom": "^1.0.1",
    "prism-react-renderer": "^2.0.4",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.1.2",
    "@commitlint/config-conventional": "^17.1.0",
    "@docusaurus/eslint-plugin": "^2.4.3",
    "@docusaurus/module-type-aliases": "2.4.3",
    "@tsconfig/docusaurus": "^1.0.7",
    "@types/node": "^20.1.4",
    "@types/react": "^18.2.13",
    "@typescript-eslint/eslint-plugin": "^5.59.5",
    "@typescript-eslint/parser": "^5.59.5",
    "commitizen": "^4.2.5",
    "cz-conventional-changelog": "^3.3.0",
    "cz-customizable": "^7.0.0",
    "eslint": "^8.40.0",
    "eslint-config-standard-with-typescript": "^34.0.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-n": "^15.0.0",
    "eslint-plugin-promise": "^6.0.0",
    "eslint-plugin-react": "^7.32.2",
    "husky": "^8.0.1",
    "typescript": "^4.9.5"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=16.14"
  },
  "lint-staged": {
    "*.{.ts,tsx,js,jsx,mjs,mdx}": [
      "pnpm lint:fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-customizable"
    }
  }
}
