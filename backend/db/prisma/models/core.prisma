generator client {
  provider   = "prisma-client"
  output     = "../generated/"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
}

model config {
  id         Int      @id @default(autoincrement())
  key        String
  module     String   @default("runtime")
  value      String   @default("")
  createTime DateTime @default(now())
  updateTime DateTime @default(now()) @updatedAt

  @@unique([key, module])
  @@index([module])
}

model openApiAccessKey {
  id          Int       @id @default(autoincrement())
  name        String    @default("")
  value       String
  expire_time DateTime?
  enable      Int       @default(1)
  createTime  DateTime  @default(now())
  updateTime  DateTime  @default(now()) @updatedAt

  @@index([value, enable])
  @@index([enable])
}
