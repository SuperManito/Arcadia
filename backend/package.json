{
  "name": "arcadia",
  "version": "1.0.0",
  "description": "arcadia",
  "engines": {
    "node": ">=20.0"
  },
  "scripts": {
    "server": "prisma generate && echo 'y' | prisma db push --accept-data-loss > ./prisma_push.log && tsx index",
    "build": "tsc",
    "tsc": "tsc --noEmit --skipLibCheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "migrate:dev": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "db:push": "prisma db push",
    "generate": "prisma generate",
    "clean": "rimraf dist && rimraf package-lock.json && rimraf node_modules"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "archiver": "^7.0.1",
    "axios": "^1.13.2",
    "body-parser": "^2.2.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "cron": "^4.3.5",
    "crypto-js": "^4.2.0",
    "express": "^5.2.1",
    "express-jwt": "^8.5.1",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "log4js": "^6.9.1",
    "multer": "^2.0.2",
    "otpauth": "^9.4.1",
    "socket.io": "^4.8.1",
    "svg-captcha": "^1.4.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.3.0",
    "@types/archiver": "^7.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "eslint": "^9.36.1",
    "prisma": "^7.1.0",
    "rimraf": "^6.1.2",
    "typescript": "~5.9.3"
  }
}
