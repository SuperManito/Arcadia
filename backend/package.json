{
  "name": "arcadia",
  "type": "module",
  "version": "1.0.0",
  "description": "arcadia",
  "engines": {
    "node": ">=20.0"
  },
  "scripts": {
    "server": "prisma generate && echo 'y' | prisma db push --accept-data-loss > ./prisma_push.log && tsx index",
    "build": "tsc",
    "tsc": "tsc --noEmit --skipLibCheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "migrate:dev": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "db:push": "prisma db push",
    "generate": "prisma generate",
    "clean": "rimraf dist && rimraf package-lock.json && rimraf node_modules"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "7.6.0",
    "@prisma/client": "7.6.0",
    "archiver": "7.0.1",
    "axios": "1.14.0",
    "better-sse": "0.16.1",
    "body-parser": "2.2.2",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "cron": "4.4.0",
    "crypto-js": "4.2.0",
    "express": "5.2.1",
    "express-jwt": "8.5.1",
    "jsonwebtoken": "9.0.3",
    "log4js": "6.9.1",
    "multer": "2.1.1",
    "node-pty": "1.1.0",
    "otpauth": "9.5.0",
    "pm2": "6.0.14",
    "socket.io": "4.8.3",
    "svg-captcha": "1.4.0",
    "tsx": "4.21.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@types/archiver": "^7.0.0",
    "@types/compression": "^1.8.1",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "eslint": "^9.39.4",
    "prisma": "^7.5.0",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3"
  }
}
